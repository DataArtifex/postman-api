{
    "info": {
        "name": "Get City Weather",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "description": {
            "content": "This collection is used to get the weather of a city",
            "type": "string"
        },
        "version": {
            "major": 1,
            "minor": 0,
            "patch": 0
        }
    },
    "item": [
        {
            "request": {
                "url": {
                    "raw": "https://api.openweathermap.org/data/2.5/weather?q=city&appid=your_api_key",
                    "protocol": "https",
                    "host": [
                        "api",
                        "openweathermap",
                        "org"
                    ],
                    "path": [
                        "data",
                        "2.5",
                        "weather"
                    ],
                    "query": [
                        {
                            "key": "q",
                            "value": "city"
                        },
                        {
                            "key": "appid",
                            "value": "your_api_key"
                        }
                    ]
                },
                "method": "GET",
                "description": {
                    "content": "Get the weather of a city by providing the city name and your API key",
                    "type": "string"
                },
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ]
            },
            "name": "Get City Weather"
        }
    ]
}